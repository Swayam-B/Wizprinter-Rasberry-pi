<LandingScreen>:
    canvas.before:
        Color:
            rgba: 0, 0, 0, 1
        Rectangle:
            pos: self.pos
            size: self.size

    FloatLayout:
        # 1. BRANDING GROUP
        FloatLayout:
            size_hint: (None, None)
            size: dp(200), dp(240)
            # Keeping the whole group pinned near the top
            pos_hint: {'center_x': 0.5, 'top': 0.95}

            Image:
                source: 'assets/logo/whiteLogo.png'
                size_hint: (None, None)
                size: dp(200), dp(200)
                pos_hint: {'center_x': 0.5, 'top': 1} 
                allow_stretch: True
                keep_ratio: True

            Label:
                text: 'WizPrinter'
                font_size: '38sp'
                bold: True
                color: [1, 1, 1, 1]
                size_hint: (None, None)
                size: self.texture_size
                # --- THE ADJUSTMENT ---
                # Changed from 0.15 to 0.3 to pull the text HIGHER into the logo
                pos_hint: {'center_x': 0.5, 'center_y': 0.3}

        # 2. THE BUTTON
        Button:
            text: 'TAP TO START'
            size_hint: (0.85, None)
            height: dp(60)
            pos_hint: {'center_x': 0.5, 'y': 0.1}
            font_size: '22sp'
            bold: True
            color: [1, 1, 1, 1]
            background_color: 0, 0, 0, 0
            on_release: root.on_tap_start()
            canvas.before:
                Color:
                    rgba: PRIMARY_COLOR
                RoundedRectangle:
                    pos: self.pos
                    size: self.size
                    radius: [12]