<ScanScreen>:
    canvas.before:
        Color:
            rgba: BG_DARK
        Rectangle:
            pos: self.pos
            size: self.size

    BoxLayout:
        orientation: 'vertical'

        # Custom StatusBar
        BoxLayout:
            size_hint_y: None
            height: dp(45)
            padding: [dp(10), 0]
            canvas.before:
                Color:
                    rgba: 0.043, 0.071, 0.094, 1
                Rectangle:
                    pos: self.pos
                    size: self.size
            Label:
                text: 'Scan Document'
                bold: True
                halign: 'left'
                text_size: self.size
                valign: 'middle'
            Label:
                text: root.page_info
                size_hint_x: None
                width: dp(80)
                font_size: '12sp'
                color: 0.7, 0.7, 0.7, 1

        BoxLayout:
            orientation: 'horizontal'
            size_hint_y: 1
            padding: dp(8)
            spacing: dp(12)

            # Left side: PREVIEW LIST
            BoxLayout:
                size_hint_x: 0.65
                orientation: 'vertical'
                padding: dp(2)
                canvas.before:
                    Color:
                        rgba: 0.043, 0.071, 0.094, 1
                    RoundedRectangle:
                        pos: self.pos
                        size: self.size
                        radius: [6]

                ScrollView:
                    do_scroll_x: False
                    do_scroll_y: True
                    bar_width: dp(4)
                    
                    GridLayout:
                        id: thumbnail_grid
                        cols: 1
                        spacing: dp(10)
                        padding: dp(10)
                        size_hint_y: None
                        height: self.minimum_height # Required for scrolling

                        # This effectively 'loops' through the scanned_images list
                        # We use a helper to clear and re-add in Python or 
                        # use a dynamic approach here:
                        BoxLayout:
                            orientation: 'vertical'
                            size_hint_y: None
                            height: self.minimum_height
                            
                            # Kivy doesn't have a native 'for each' in KV, 
                            # so we'll use a Factory or simple dynamic generation
                            # For now, let's simplify the KV to show the LATEST page
                            # and I'll show you the Python 'loop' fix below.
                            Image:
                                source: root.scanned_images[-1] if root.scanned_images else ''
                                size_hint_y: None
                                height: self.width * 1.41
                                allow_stretch: True
                                keep_ratio: True

            # Right side: Control Buttons
            BoxLayout:
                size_hint_x: 0.35
                orientation: 'vertical'
                spacing: dp(10)

                # ADD PAGE
                Button:
                    text: '+ PAGE'
                    font_size: '11sp'
                    size_hint_y: 1
                    background_color: (0, 0, 0, 0)
                    disabled: root.is_scanning
                    on_release: root.add_page()
                    canvas.before:
                        Color:
                            rgba: (0.1, 0.2, 0.3, 1) if self.disabled else (0.137, 0.267, 0.388, 1)
                        RoundedRectangle:
                            pos: self.pos
                            size: self.size
                            radius: [6]

                # DELETE PAGE
                Button:
                    text: 'DEL'
                    font_size: '11sp'
                    size_hint_y: 1
                    background_color: (0, 0, 0, 0)
                    disabled: root.is_scanning or not root.scanned_images
                    on_release: root.delete_page()
                    canvas.before:
                        Color:
                            rgba: (0.1, 0.2, 0.3, 1) if self.disabled else (0.137, 0.267, 0.388, 1)
                        RoundedRectangle:
                            pos: self.pos
                            size: self.size
                            radius: [6]

                # DONE / UPLOAD
                Button:
                    text: 'DONE'
                    font_size: '13sp'
                    bold: True
                    size_hint_y: 1.8
                    background_color: (0, 0, 0, 0)
                    disabled: root.is_scanning or not root.scanned_images
                    on_release: root.upload()
                    canvas.before:
                        Color:
                            rgba: (0.1, 0.3, 0.1, 1) if self.disabled else SUCCESS_COLOR
                        RoundedRectangle:
                            pos: self.pos
                            size: self.size
                            radius: [6]