<ScanScreen>:
    canvas.before:
        Color:
            rgba: BG_DARK
        Rectangle:
            pos: self.pos
            size: self.size

    BoxLayout:
        orientation: 'vertical'

        StatusBar:
            size_hint_y: None
            height: dp(45)
            title: 'Scan Document'

        BoxLayout:
            orientation: 'horizontal'
            size_hint_y: 1
            padding: dp(4)
            spacing: dp(8)

            BoxLayout:
                size_hint_x: 0.65
                orientation: 'vertical'
                padding: dp(4)
                canvas.before:
                    Color:
                        rgba: 0.043, 0.071, 0.094, 1
                    RoundedRectangle:
                        pos: self.pos
                        size: self.size
                        radius: [6]

                AnchorLayout:
                    Widget:
                        size_hint: 0.9, 0.95
                        canvas:
                            Color:
                                rgba: 1, 1, 1, 1
                            Rectangle:
                                pos: self.pos
                                size: self.size
                            Color:
                                rgba: 0.9, 0.9, 0.9, 1
                            Rectangle:
                                pos: self.x + dp(2), self.y + dp(2)
                                size: self.width - dp(4), self.height - dp(4)

            BoxLayout:
                size_hint_x: 0.35
                orientation: 'vertical'
                spacing: dp(6)

                Button:
                    text: '+ PAGE'
                    font_size: '11sp'
                    size_hint_y: 1
                    background_color: (0, 0, 0, 0)
                    on_release: root.add_page()
                    canvas.before:
                        Color:
                            rgba: 0.137, 0.267, 0.388, 1
                        RoundedRectangle:
                            pos: self.pos
                            size: self.size
                            radius: [6]

                Button:
                    text: 'DEL'
                    font_size: '11sp'
                    size_hint_y: 1
                    background_color: (0, 0, 0, 0)
                    on_release: root.delete_page()
                    canvas.before:
                        Color:
                            rgba: 0.137, 0.267, 0.388, 1
                        RoundedRectangle:
                            pos: self.pos
                            size: self.size
                            radius: [6]

                Button:
                    text: 'DONE'
                    font_size: '13sp'
                    bold: True
                    size_hint_y: 1.8
                    background_color: (0, 0, 0, 0)
                    on_release: root.upload()
                    canvas.before:
                        Color:
                            rgba: PRIMARY_COLOR
                        RoundedRectangle:
                            pos: self.pos
                            size: self.size
                            radius: [6]