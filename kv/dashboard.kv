<DashboardScreen>:
    canvas.before:
        Color:
            rgba: BG_DARK
        Rectangle:
            pos: self.pos
            size: self.size

    BoxLayout:
        orientation: 'vertical'

        BoxLayout:
            size_hint_y: None
            height: dp(50)
            padding: [dp(16), dp(8)]
            canvas.before:
                Color:
                    rgba: BG_DARK
                Rectangle:
                    pos: self.pos
                    size: self.size
                Color:
                    rgba: 0.075, 0.498, 0.925, 0.2
                Line:
                    points: [self.x, self.y, self.right, self.y]
            BoxLayout:
                size_hint_x: 0.4
                spacing: dp(8)
                Label:
                    text: '[P]'
                    font_size: '18sp'
                    bold: True
                    color: PRIMARY_COLOR
                    size_hint_x: None
                    width: dp(30)
                Label:
                    text: 'WizPrinter'
                    font_size: '16sp'
                    bold: True
                    color: WHITE
                    halign: 'left'
                    valign: 'middle'
                    text_size: self.size

            # Right: status
            BoxLayout:
                size_hint_x: 0.6
                spacing: dp(8)
                Widget:
                Widget:
                    size_hint: None, None
                    size: dp(10), dp(10)
                    pos_hint: {'center_y': 0.5}
                    canvas:
                        Color:
                            rgba: SUCCESS_COLOR
                        Ellipse:
                            pos: self.pos
                            size: dp(8), dp(8)
                
                Label:
                    text: 'READY'
                    font_size: '12sp'
                    color: 1, 1, 1, 0.5
                    size_hint_x: None
                    width: dp(50)
                
                Label:
                    text: root.current_time
                    font_size: '14sp'
                    bold: True
                    color: WHITE
                    size_hint_x: None
                    width: dp(80)
                    halign: 'right'
                    valign: 'middle'
                    text_size: self.size
        GridLayout:
            cols: 2
            padding: dp(16)
            spacing: dp(16)
            Button:
                background_color: 0, 0, 0, 0
                on_release: root.nav_grade()
                canvas.before:
                    Color:
                        rgba: BG_CARD
                    RoundedRectangle:
                        pos: self.pos
                        size: self.size
                        radius: [12]
                    Color:
                        rgba: 0.3, 0.35, 0.45, 1
                    Line:
                        rounded_rectangle: [self.x, self.y, self.width, self.height, 12]
                
                BoxLayout:
                    orientation: 'vertical'
                    pos: self.parent.pos
                    size: self.parent.size
                    padding: dp(10)
                    Label:
                        text: 'GRADE'
                        font_size: '22sp'
                        bold: True
                        color: PRIMARY_COLOR
                    Label:
                        text: 'grade'
                        font_size: '12sp'
                        color: WHITE
                        opacity: 0.6
            Button:
                background_color: 0, 0, 0, 0
                on_release: root.nav_scan()
                canvas.before:
                    Color:
                        rgba: BG_CARD
                    RoundedRectangle:
                        pos: self.pos
                        size: self.size
                        radius: [12]
                    Color:
                        rgba: 0.3, 0.35, 0.45, 1
                    Line:
                        rounded_rectangle: [self.x, self.y, self.width, self.height, 12]
                
                BoxLayout:
                    orientation: 'vertical'
                    pos: self.parent.pos
                    size: self.parent.size
                    padding: dp(10)
                    Label:
                        text: 'SCAN'
                        font_size: '22sp'
                        bold: True
                        color: PRIMARY_COLOR
                    Label:
                        text: 'scan'
                        font_size: '12sp'
                        color: WHITE
                        opacity: 0.6
            Button:
                background_color: 0, 0, 0, 0
                on_release: root.nav_classes()
                canvas.before:
                    Color:
                        rgba: BG_CARD
                    RoundedRectangle:
                        pos: self.pos
                        size: self.size
                        radius: [12]
                    Color:
                        rgba: 0.3, 0.35, 0.45, 1
                    Line:
                        rounded_rectangle: [self.x, self.y, self.width, self.height, 12]
                
                BoxLayout:
                    orientation: 'vertical'
                    pos: self.parent.pos
                    size: self.parent.size
                    padding: dp(10)
                    Label:
                        text: 'CLASSES'
                        font_size: '22sp'
                        bold: True
                        color: PRIMARY_COLOR
                    Label:
                        text: 'classes'
                        font_size: '12sp'
                        color: WHITE
                        opacity: 0.6
            Button:
                background_color: 0, 0, 0, 0
                on_release: root.nav_settings()
                canvas.before:
                    Color:
                        rgba: BG_CARD
                    RoundedRectangle:
                        pos: self.pos
                        size: self.size
                        radius: [12]
                    Color:
                        rgba: 0.3, 0.35, 0.45, 1
                    Line:
                        rounded_rectangle: [self.x, self.y, self.width, self.height, 12]
                
                BoxLayout:
                    orientation: 'vertical'
                    pos: self.parent.pos
                    size: self.parent.size
                    padding: dp(10)
                    Label:
                        text: 'SETTINGS'
                        font_size: '22sp'
                        bold: True
                        color: PRIMARY_COLOR
                    Label:
                        text: 'settings'
                        font_size: '12sp'
                        color: WHITE
                        opacity: 0.6
        BottomNav:
            active_tab: 'home'
            size_hint_y: None
            height: dp(60)