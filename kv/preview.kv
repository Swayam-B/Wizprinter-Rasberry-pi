<PreviewScreen>:
    canvas.before:
        Color:
            rgba: BG_DARK
        Rectangle:
            pos: self.pos
            size: self.size

    BoxLayout:
        orientation: 'vertical'

        # --- Top Status Bar ---
        BoxLayout:
            size_hint_y: None
            height: '40dp'
            padding: ['8dp', '4dp']
            canvas.before:
                Color:
                    rgba: BG_DARK
                Rectangle:
                    pos: self.pos
                    size: self.size
                Color:
                    rgba: 1, 1, 1, 0.1
                Line:
                    points: [self.x, self.y, self.right, self.y]
            
            Button:
                size_hint: None, 1
                width: '36dp'
                background_color: TRANSPARENT
                on_release: root.go_back()
                Widget:
                    center: self.parent.center
                    size: dp(16), dp(16)
                    canvas:
                        Color:
                            rgba: WHITE
                        Line:
                            width: 1.2
                            points: [self.center_x + dp(4), self.center_y - dp(6), self.center_x - dp(4), self.center_y, self.center_x + dp(4), self.center_y + dp(6)]

            Label:
                text: 'Document Preview'
                font_size: '14sp'
                bold: True
                color: WHITE
                text_size: self.size
                halign: 'left'
                valign: 'middle'
            
            Label:
                size_hint_x: None
                width: '60dp'
                text: root.page_info
                font_size: '10sp'
                bold: True
                color: 0.4, 0.4, 0.4, 1
                text_size: self.size
                halign: 'right'
                valign: 'middle'
        # --- Preview Content Area ---
        FloatLayout:
            ScrollView:
                id: scroll_container
                size_hint: 0.9, 0.82
                pos_hint: {'center_x': 0.5, 'center_y': 0.55}
                do_scroll_x: False
                do_scroll_y: True
                
                canvas.before:
                    Color:
                        rgba: 1, 1, 1, 1
                    RoundedRectangle:
                        pos: self.pos
                        size: self.size
                        radius: [4]

                # This grid allows us to stack the pages exactly like the scan thumbnails
                GridLayout:
                    id: preview_container
                    cols: 1
                    size_hint_y: None
                    height: self.minimum_height
                    spacing: dp(10)
                    padding: dp(5)

            # --- Floating Action Buttons ---
            BoxLayout:
                pos_hint: {'center_x': 0.5, 'y': 0.02}
                size_hint: 0.9, None
                height: '72dp'
                spacing: '12dp'

                Button:
                    background_color: TRANSPARENT
                    on_release: root.delete_document()
                    canvas.before:
                        Color:
                            rgba: DANGER_COLOR
                        Ellipse:
                            pos: self.center_x - dp(28), self.center_y - dp(28)
                            size: dp(56), dp(56)
                    Label:
                        text: 'DELETE'
                        font_size: '8sp'
                        bold: True
                        center: self.parent.center

                Button:
                    background_color: TRANSPARENT
                    on_release: root.grade_document()
                    canvas.before:
                        Color:
                            rgba: PRIMARY_COLOR
                        Ellipse:
                            pos: self.center_x - dp(34), self.center_y - dp(34)
                            size: dp(68), dp(68)
                    Label:
                        text: 'GRADE'
                        font_size: '10sp'
                        bold: True
                        center: self.parent.center

                Button:
                    background_color: TRANSPARENT
                    on_release: root.print_document()
                    canvas.before:
                        Color:
                            rgba: SUCCESS_COLOR
                        Ellipse:
                            pos: self.center_x - dp(28), self.center_y - dp(28)
                            size: dp(56), dp(56)
                    Label:
                        text: 'PRINT'
                        font_size: '8sp'
                        bold: True
                        center: self.parent.center