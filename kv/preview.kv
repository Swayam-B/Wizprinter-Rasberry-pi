<PreviewScreen>:
    canvas.before:
        Color:
            rgba: BG_DARK
        Rectangle:
            pos: self.pos
            size: self.size

    BoxLayout:
        orientation: 'vertical'

        # StatusBar
        BoxLayout:
            size_hint_y: None
            height: '40dp'
            padding: ['8dp', '4dp']
            canvas.before:
                Color:
                    rgba: BG_DARK
                Rectangle:
                    pos: self.pos
                    size: self.size
                Color:
                    rgba: 1, 1, 1, 0.1
                Line:
                    points: [self.x, self.y, self.right, self.y]
            
            Button:
                size_hint: None, 1
                width: '36dp'
                background_color: TRANSPARENT
                on_release: root.go_back()
                # Replacing the Label with a Canvas arrow for Pi compatibility
                Widget:
                    center: self.parent.center
                    size: dp(16), dp(16)
                    canvas:
                        Color:
                            rgba: WHITE
                        Line:
                            width: 1.2
                            points: [self.center_x + dp(4), self.center_y - dp(6), self.center_x - dp(4), self.center_y, self.center_x + dp(4), self.center_y + dp(6)]

            Label:
                text: 'Document Preview'
                font_size: '14sp'
                bold: True
                color: WHITE
                text_size: self.size
                halign: 'left'
                valign: 'middle'
            
            Label:
                size_hint_x: None
                width: '60dp'
                text: root.page_info
                font_size: '10sp'
                bold: True
                color: 0.4, 0.4, 0.4, 1
                text_size: self.size
                halign: 'right'
                valign: 'middle'
        # Preview area - NOW SHOWING REAL IMAGES
        FloatLayout:
            # The PDF Page Container
            BoxLayout:
                pos_hint: {'center_x': 0.5, 'center_y': 0.55}
                size_hint: 0.85, 0.85
                canvas.before:
                    Color:
                        rgba: 1, 1, 1, 1 # White paper background
                    RoundedRectangle:
                        pos: self.pos
                        size: self.size
                        radius: [4]
                    # Drop shadow effect
                    Color:
                        rgba: 0, 0, 0, 0.3
                    Line:
                        width: 1
                        rectangle: [self.x, self.y, self.width, self.height]
                
                # --- ACTUAL PDF IMAGE ---
                Image:
                    id: preview_image
                    source: root.current_page_source  # Path to the converted image file
                    allow_stretch: True
                    keep_ratio: True
                    # This ensures the image fills the "paper" area cleanly
                    size_hint: 0.95, 0.95
                    pos_hint: {'center_x': 0.5, 'center_y': 0.5}

            # Floating action buttons
            BoxLayout:
                pos_hint: {'center_x': 0.5, 'y': 0.02}
                size_hint: 0.9, None
                height: '72dp'
                spacing: '12dp'

                # DELETE
                Button:
                    background_color: TRANSPARENT
                    on_release: root.delete_document()
                    canvas.before:
                        Color:
                            rgba: DANGER_COLOR
                        Ellipse:
                            pos: self.center_x - dp(28), self.center_y - dp(28)
                            size: dp(56), dp(56)
                    Label:
                        text: 'DELETE'
                        font_size: '8sp'
                        bold: True
                        center: self.parent.center

                # GRADE - Spans slightly larger
                Button:
                    background_color: TRANSPARENT
                    on_release: root.grade_document()
                    canvas.before:
                        Color:
                            rgba: PRIMARY_COLOR
                        Ellipse:
                            pos: self.center_x - dp(34), self.center_y - dp(34)
                            size: dp(68), dp(68)
                    Label:
                        text: 'GRADE'
                        font_size: '10sp'
                        bold: True
                        center: self.parent.center

                # PRINT
                Button:
                    background_color: TRANSPARENT
                    on_release: root.print_document()
                    canvas.before:
                        Color:
                            rgba: SUCCESS_COLOR
                        Ellipse:
                            pos: self.center_x - dp(28), self.center_y - dp(28)
                            size: dp(56), dp(56)
                    Label:
                        text: 'PRINT'
                        font_size: '8sp'
                        bold: True
                        center: self.parent.center