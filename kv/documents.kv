#:import dp kivy.metrics.dp

<DocumentItem@ButtonBehavior+BoxLayout>:
    doc_name: ''
    doc_date: ''
    orientation: 'horizontal'
    size_hint_y: None
    height: dp(50)
    padding: [dp(15), dp(5)]
    spacing: dp(15)
    canvas.before:
        Color:
            rgba: (1, 1, 1, 0.05) if self.state == 'normal' else (0.075, 0.498, 0.925, 0.2)
        Rectangle:
            pos: self.pos
            size: self.size
        Color:
            rgba: (1, 1, 1, 0.1)
        Line:
            points: [self.x, self.y, self.right, self.y]

    # --- CANVAS FILE ICON (Fixes the "??") ---
    Widget:
        size_hint_x: None
        width: dp(24)
        canvas:
            Color:
                rgba: (0.075, 0.498, 0.925, 1) # WizPrinter Blue
            # Main file body
            Line:
                width: dp(1)
                points: [self.x, self.y, self.x, self.top, self.right - dp(6), self.top, self.right, self.top - dp(6), self.right, self.y, self.x, self.y]
            # Dog-ear corner fold
            Line:
                width: dp(1)
                points: [self.right - dp(6), self.top, self.right - dp(6), self.top - dp(6), self.right, self.top - dp(6)]

    BoxLayout:
        orientation: 'vertical'
        Label:
            text: root.doc_name
            font_size: '14sp'
            bold: True
            text_size: self.size
            halign: 'left'
            valign: 'bottom'
        Label:
            text: root.doc_date
            font_size: '11sp'
            color: (1, 1, 1, 0.5)
            text_size: self.size
            halign: 'left'
            valign: 'top'

    Label:
        text: '>'
        font_size: '16sp'
        size_hint_x: None
        width: dp(20)
        color: (0.075, 0.498, 0.925, 1)

<DocumentsScreen>:
    canvas.before:
        Color:
            rgba: BG_DARK
        Rectangle:
            pos: self.pos
            size: self.size

    BoxLayout:
        orientation: 'vertical'

        StatusBar:
            size_hint_y: None
            height: dp(45)
            title: 'Select Document'
            show_back: True
            # Ensures back always goes to dashboard
            on_back: app.root.current = 'dashboard'

        ScrollView:
            size_hint_y: 1
            do_scroll_x: False
            BoxLayout:
                id: doc_list
                orientation: 'vertical'
                size_hint_y: None
                height: self.minimum_height
                
                # --- CONNECTED MOCK PDFs ---
                DocumentItem:
                    doc_name: 'WizPrinterTest1.pdf'
                    doc_date: 'Mar 10, 2026'
                    on_release: root.select_document(self.doc_name)
                
                DocumentItem:
                    doc_name: 'oct24MultiplePage.pdf'
                    doc_date: 'Oct 24, 2025'
                    on_release: root.select_document(self.doc_name)
                
                DocumentItem:
                    doc_name: 'oct24MultiplePageAnswered.pdf'
                    doc_date: 'Oct 24, 2025'
                    on_release: root.select_document(self.doc_name)

        BottomNav:
            active_tab: 'documents'
            size_hint_y: None
            height: dp(45)