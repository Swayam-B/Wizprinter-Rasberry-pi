<GradeScreen>:
    canvas.before:
        Color:
            rgba: BG_DARK
        Rectangle:
            pos: self.pos
            size: self.size

    BoxLayout:
        orientation: 'vertical'

        # 1. Standardized Status Bar (Includes your custom Home/Back logic)
        StatusBar:
            title: 'Grade Document'
            size_hint_y: None
            height: dp(45)

        # 2. Expanded Middle Layout
        BoxLayout:
            orientation: 'horizontal'
            size_hint_y: 1  # Fills the remaining screen
            padding: dp(8)
            spacing: dp(12)

            # Left: Document preview
            BoxLayout:
                size_hint_x: 0.6
                padding: dp(8)
                canvas.before:
                    Color:
                        rgba: 0.098, 0.149, 0.200, 0.5
                    RoundedRectangle:
                        pos: self.pos
                        size: self.size
                        radius: [8]
                
                AnchorLayout:
                    # Paper Preview
                    Widget:
                        size_hint: 0.85, 0.95
                        canvas:
                            Color:
                                rgba: 1, 1, 1, 1
                            Rectangle:
                                pos: self.pos
                                size: self.size
                            Color:
                                rgba: 0.85, 0.85, 0.85, 1
                            Rectangle:
                                pos: self.x + dp(4), self.y + dp(4)
                                size: self.width - dp(8), self.height - dp(8)

            # Right: Action buttons
            BoxLayout:
                size_hint_x: 0.4
                orientation: 'vertical'
                spacing: dp(8)

                # Add Page
                Button:
                    text: '+ PAGE'
                    font_size: '11sp'
                    bold: True
                    color: PRIMARY_COLOR
                    background_color: 0, 0, 0, 0
                    on_release: root.add_page()
                    canvas.before:
                        Color:
                            rgba: 0.075, 0.498, 0.925, 0.1
                        RoundedRectangle:
                            pos: self.pos
                            size: self.size
                            radius: [8]
                        Color:
                            rgba: 0.075, 0.498, 0.925, 0.4
                        Line:
                            rounded_rectangle: [self.x, self.y, self.width, self.height, 8]


                # Delete
                Button:
                    text: 'DELETE'
                    font_size: '11sp'
                    bold: True
                    color: (0.9, 0.3, 0.2, 1) # DANGER_COLOR fallback
                    background_color: 0, 0, 0, 0
                    on_release: root.delete_page()
                    canvas.before:
                        Color:
                            rgba: 0.9, 0.3, 0.2, 0.1
                        RoundedRectangle:
                            pos: self.pos
                            size: self.size
                            radius: [8]
                        Color:
                            rgba: 0.9, 0.3, 0.2, 0.4
                        Line:
                            rounded_rectangle: [self.x, self.y, self.width, self.height, 8]

                # Grade Now (Primary action)
                Button:
                    size_hint_y: 1.5
                    text: 'GRADE NOW'
                    font_size: '13sp'
                    bold: True
                    color: WHITE
                    background_color: 0, 0, 0, 0
                    on_release: root.grade_now()
                    canvas.before:
                        Color:
                            rgba: PRIMARY_COLOR
                        RoundedRectangle:
                            pos: self.pos
                            size: self.size
                            radius: [8]

        # 3. Bottom Accent (Slimmed down to maximize space)
        Widget:
            size_hint_y: None
            height: dp(2)
            canvas:
                Color:
                    rgba: PRIMARY_COLOR
                Rectangle:
                    pos: self.pos
                    size: self.size