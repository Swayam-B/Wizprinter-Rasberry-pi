<StatusBar>:
    title: ''
    hide_home: False  
    show_back: False  # NEW: Property for the Login screen
    
    orientation: 'horizontal'
    size_hint_y: None
    height: dp(45)
    padding: [dp(5), 0]

    # LEFT BUTTON SLOT (Back or Home)
    Button:
        size_hint: (None, None) if (not root.hide_home or root.show_back) else (0, 0)
        width: dp(50) if (not root.hide_home or root.show_back) else 0
        height: dp(45)
        background_color: 0, 0, 0, 0
        
        on_release: 
            # Priority 1: Custom back action defined in the Screen (e.g., Settings)
            if root.show_back and root.back: root.back()
            # Priority 2: Default back logic
            elif root.show_back: root.go_back()
            # Priority 3: Home/Dashboard logic
            elif not root.hide_home: app.root.current = 'dashboard'
        
        canvas.after:
            Color:
                rgba: PRIMARY_COLOR if (not root.hide_home or root.show_back) else [0,0,0,0]
            
            # Draw Back Arrow if show_back is True
            Line:
                width: dp(1.5)
                points: 
                    [self.center_x + dp(5), self.center_y - dp(8), self.center_x - dp(5), self.center_y, self.center_x + dp(5), self.center_y + dp(8)] if root.show_back else [0,0,0,0,0,0]
            
            # Draw Home Icon ONLY if show_back is False and hide_home is False
            Triangle:
                points: [self.x + dp(15), self.y + dp(22), self.right - dp(15), self.y + dp(22), self.center_x, self.y + dp(34)] if (not root.hide_home and not root.show_back) else [0,0,0,0,0,0]
            Rectangle:
                pos: (self.center_x - dp(7), self.y + dp(12)) if (not root.hide_home and not root.show_back) else (0,0)
                size: (dp(14), dp(10)) if (not root.hide_home and not root.show_back) else (0,0)

    Label:
        text: root.title
        font_size: '14sp'
        bold: True
        color: WHITE
        halign: 'left'
        valign: 'middle'
        text_size: self.size